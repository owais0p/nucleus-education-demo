---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nucleus Education | Kota's Premier IIT-JEE & NEET Coaching">
	<!-- Hero Section -->
	<section class="relative bg-navy text-white min-h-[85vh] flex flex-col items-center justify-center px-4 overflow-hidden py-12">
		<!-- Advanced Background -->
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,_rgba(30,144,255,0.15),transparent_50%)]"></div>
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_70%,_rgba(30,144,255,0.1),transparent_50%)]"></div>
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-electric/5 rounded-full blur-[120px] -translate-y-1/2"></div>
		
		<!-- Decorative lines -->
		<div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>

		<div class="container mx-auto text-center relative z-10">
			<div class="inline-flex items-center gap-2 px-3 py-1 mb-6 border border-white/10 bg-white/5 backdrop-blur-md text-electric rounded-full text-[9px] font-bold tracking-[0.2em] uppercase animate-reveal" style="animation-delay: 0.1s">
				<span class="w-1.5 h-1.5 bg-electric rounded-full animate-pulse"></span>
				Admission Open 2026-27
			</div>
			
			<h1 class="font-outfit text-4xl md:text-7xl font-extrabold mb-4 tracking-tight leading-[1.1] animate-reveal" style="animation-delay: 0.2s">
				NUCLEUS<br/>
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-electric to-white/50">EDUCATION</span>
			</h1>
			
			<p class="font-jakarta text-sm md:text-lg text-gray-400 mb-8 max-w-xl mx-auto leading-relaxed animate-reveal italic font-light" style="animation-delay: 0.3s">
				Crafting <span class="text-white font-fraunces italic">extraordinary</span> futures in Kota since the dawn of excellence. 
				Join the legacy of <span class="text-white font-medium">IIT-JEE & NEET</span> success.
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-reveal" style="animation-delay: 0.4s">
				<a href="https://wa.me/910000000000" class="group relative bg-electric text-white font-bold py-3.5 px-8 rounded-full transition-all overflow-hidden text-xs">
					<span class="relative z-10 flex items-center gap-3">
						Enquire for 2026
						<svg class="group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</span>
					<div class="absolute inset-0 bg-white transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left opacity-10"></div>
				</a>
				<a href="#courses" class="text-white font-bold py-3.5 px-8 rounded-full border border-white/20 hover:bg-white/5 transition-all text-[10px] uppercase tracking-widest">
					Explore Courses
				</a>
			</div>
		</div>

		<!-- Scroll Indicator -->
		<div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce opacity-30">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
		</div>
	</section>

	<!-- Courses Section -->
	<section id="courses" class="py-24 px-4 bg-white relative">
		<div class="container mx-auto">
			<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
				<div class="max-w-2xl">
					<h2 class="font-outfit text-4xl md:text-5xl font-extrabold mb-4 text-navy leading-tight">
						Master the <span class="text-electric">Curriculum</span>.
					</h2>
					<p class="font-jakarta text-gray-500 text-base italic font-light">
						Precision-engineered batches designed for the elite. 
						Our results are the echoes of our commitment.
					</p>
				</div>
				<div class="hidden md:block">
					<div class="w-20 h-20 bg-electric/5 rounded-full flex items-center justify-center border border-electric/10">
						<svg class="text-electric" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
					</div>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- IIT JEE Card -->
				<div class="reveal-on-scroll bg-gray-50 rounded-[32px] p-8 border border-gray-100 hover:border-electric/30 transition-all duration-500 hover:-translate-y-2 group">
					<div class="flex justify-between items-start mb-8">
						<div class="bg-navy text-white w-14 h-14 rounded-xl flex items-center justify-center group-hover:bg-electric transition-all duration-500 rotate-3 group-hover:rotate-0 shadow-lg shadow-navy/20">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
						</div>
						<span class="text-[10px] font-bold text-gray-400 tracking-widest uppercase">Batch 01</span>
					</div>
					<h3 class="font-outfit text-2xl font-bold mb-3 text-navy">IIT JEE Advanced</h3>
					<div class="flex items-baseline gap-2 mb-6">
						<span class="text-2xl font-bold text-navy italic">₹1.0L</span>
						<span class="text-gray-400 text-xs italic font-light">/ annually</span>
					</div>
					<ul class="space-y-3 mb-8 text-gray-500 font-light text-sm">
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> Comprehensive High-Yield Material</li>
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> Mentorship by HODs</li>
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> Advanced Ranker's Test Series</li>
					</ul>
					<a href="https://wa.me/910000000000" class="flex items-center justify-between w-full bg-navy text-white font-bold py-4 px-6 rounded-xl hover:bg-electric transition-colors duration-500 group-hover:shadow-xl group-hover:shadow-electric/20 text-sm">
						Apply Now
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</a>
				</div>

				<!-- NEET Card -->
				<div class="reveal-on-scroll bg-navy text-white rounded-[32px] p-8 relative overflow-hidden transition-all duration-500 hover:-translate-y-2 group shadow-2xl shadow-navy/20">
					<div class="absolute top-0 right-0 w-32 h-32 bg-electric/20 rounded-full blur-3xl -mr-16 -mt-16"></div>
					<div class="absolute top-6 right-8">
						<span class="bg-electric text-white text-[9px] font-bold px-2 py-1 rounded-full uppercase tracking-[0.15em] shadow-lg shadow-electric/50">Most Elite</span>
					</div>
					<div class="flex justify-between items-start mb-8">
						<div class="bg-white text-navy w-14 h-14 rounded-xl flex items-center justify-center rotate-3 group-hover:rotate-0 transition-all duration-500">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="m7 7 10 10"></path><path d="m17 7-10 10"></path></svg>
						</div>
					</div>
					<h3 class="font-outfit text-2xl font-bold mb-3">NEET UG</h3>
					<div class="flex items-baseline gap-2 mb-6">
						<span class="text-2xl font-bold italic">₹70K</span>
						<span class="text-gray-400 text-xs italic font-light">/ annually</span>
					</div>
					<ul class="space-y-3 mb-8 text-gray-300 font-light text-sm">
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> NCERT Masterclass Program</li>
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> Personalized Performance Tracker</li>
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> 24/7 Academic Concierge</li>
					</ul>
					<a href="https://wa.me/910000000000" class="flex items-center justify-between w-full bg-white text-navy font-bold py-4 px-6 rounded-xl hover:bg-electric hover:text-white transition-all duration-500 shadow-xl shadow-white/5 text-sm">
						Apply Now
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</a>
				</div>

				<!-- Foundation Card -->
				<div class="reveal-on-scroll bg-gray-50 rounded-[32px] p-8 border border-gray-100 hover:border-electric/30 transition-all duration-500 hover:-translate-y-2 group">
					<div class="flex justify-between items-start mb-8">
						<div class="bg-navy text-white w-14 h-14 rounded-xl flex items-center justify-center group-hover:bg-electric transition-all duration-500 rotate-3 group-hover:rotate-0 shadow-lg shadow-navy/20">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
						</div>
						<span class="text-[10px] font-bold text-gray-400 tracking-widest uppercase">Batch 03</span>
					</div>
					<h3 class="font-outfit text-2xl font-bold mb-3 text-navy">Foundation (6-10)</h3>
					<div class="flex items-baseline gap-2 mb-6">
						<span class="text-2xl font-bold text-navy italic">Custom</span>
						<span class="text-gray-400 text-xs italic font-light">/ by grade</span>
					</div>
					<ul class="space-y-3 mb-8 text-gray-500 font-light text-sm">
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> NTSE & International Olympiad</li>
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> Cognitive Development Classes</li>
						<li class="flex items-center gap-3"><div class="w-1.5 h-1.5 bg-electric rounded-full"></div> Foundation for JEE/NEET Early</li>
					</ul>
					<a href="https://wa.me/910000000000" class="flex items-center justify-between w-full bg-navy text-white font-bold py-4 px-6 rounded-xl hover:bg-electric transition-colors duration-500 text-sm">
						Apply Now
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Why Nucleus Section -->
	<section id="why-nucleus" class="py-32 px-4 bg-navy text-white relative overflow-hidden">
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,_rgba(30,144,255,0.05),transparent_70%)]"></div>
		
		<div class="container mx-auto relative z-10">
			<div class="text-center mb-20">
				<h2 class="font-outfit text-5xl md:text-7xl font-extrabold mb-6 tracking-tight">The Nucleus <span class="text-electric">Advantage</span></h2>
				<p class="font-jakarta text-gray-400 max-w-2xl mx-auto italic font-light">Where tradition meets technology to create champions.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-6 h-auto md:h-[600px]">
				<!-- Bento Item 1: Large Feature -->
				<div class="reveal-on-scroll md:col-span-2 md:row-span-2 bg-white/5 backdrop-blur-xl rounded-[40px] p-12 border border-white/10 flex flex-col justify-between group hover:bg-white/10 transition-all duration-700">
					<div>
						<div class="w-16 h-16 bg-electric rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-electric/20">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
						</div>
						<h3 class="font-outfit text-4xl font-bold mb-6">Elite Hostel Ecosystem</h3>
						<p class="text-gray-400 leading-relaxed text-lg font-light">
							Experience a curated living environment designed for peak academic performance. 
							Our hostels aren't just rooms; they are hubs of focused preparation with 24/7 warden support and healthy dining.
						</p>
					</div>
					<div class="mt-8 flex gap-2">
						<span class="px-4 py-2 bg-white/5 rounded-full text-xs font-bold uppercase tracking-widest text-electric border border-white/10">Premium</span>
						<span class="px-4 py-2 bg-white/5 rounded-full text-xs font-bold uppercase tracking-widest text-electric border border-white/10">Secure</span>
					</div>
				</div>

				<!-- Bento Item 2: Doubt Sessions -->
				<div class="reveal-on-scroll md:col-span-2 bg-white/5 backdrop-blur-xl rounded-[40px] p-10 border border-white/10 flex items-center gap-8 group hover:bg-white/10 transition-all duration-700">
					<div class="shrink-0 w-20 h-20 bg-white/10 rounded-3xl flex items-center justify-center border border-white/10 group-hover:scale-110 transition-transform duration-500">
						<svg class="text-electric" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
					</div>
					<div>
						<h3 class="font-outfit text-2xl font-bold mb-2">Infinite Doubt Support</h3>
						<p class="text-gray-400 text-sm font-light">One-on-one sessions with senior faculty to ensure no concept is left behind.</p>
					</div>
				</div>

				<!-- Bento Item 3: Periodic Tests -->
				<div class="reveal-on-scroll bg-white/5 backdrop-blur-xl rounded-[40px] p-10 border border-white/10 group hover:bg-white/10 transition-all duration-700">
					<div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-6 border border-white/10">
						<svg class="text-electric" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
					</div>
					<h3 class="font-outfit text-xl font-bold mb-2">Rigorous Testing</h3>
					<p class="text-gray-400 text-xs leading-relaxed font-light">Real-time ranking and AI-driven performance analytics.</p>
				</div>

				<!-- Bento Item 4: Digital Platform -->
				<div class="reveal-on-scroll bg-electric rounded-[40px] p-10 flex flex-col justify-between group hover:brightness-110 transition-all duration-700">
					<div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-6">
						<svg class="text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
					</div>
					<h3 class="font-outfit text-xl font-bold">Hybrid Learning</h3>
					<p class="text-white/80 text-xs font-light mt-2 italic">Kota education, anywhere in the world.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="py-32 px-4 bg-white relative overflow-hidden">
		<div class="container mx-auto max-w-6xl">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
				<div class="reveal-on-scroll">
					<h2 class="font-outfit text-6xl font-extrabold mb-8 text-navy tracking-tight italic">Let's build your <br/><span class="text-electric">Legacy</span>.</h2>
					<p class="font-jakarta text-gray-500 text-xl mb-12 font-light leading-relaxed">
						Admissions for the 2026-27 session are strictly limited. 
						Secure your place in the most coveted batches in Kota.
					</p>
					
					<div class="space-y-10">
						<div class="flex gap-6 group">
							<div class="w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center text-electric border border-gray-100 group-hover:bg-electric group-hover:text-white transition-all duration-500">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></circle><circle cx="12" cy="10" r="3"></circle></svg>
							</div>
							<div>
								<h4 class="font-outfit text-lg font-bold text-navy mb-1 uppercase tracking-widest">Global HQ</h4>
								<p class="text-gray-500 font-light max-w-xs">
									Plot No. 92, Rajeev Gandhi Nagar, Kota - 324005
								</p>
							</div>
						</div>

						<div class="flex gap-6 group">
							<div class="w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center text-electric border border-gray-100 group-hover:bg-electric group-hover:text-white transition-all duration-500">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
							</div>
							<div>
								<h4 class="font-outfit text-lg font-bold text-navy mb-1 uppercase tracking-widest">Office Hours</h4>
								<p class="text-gray-500 font-light">8AM - 10PM Everyday</p>
							</div>
						</div>
					</div>
				</div>

				<div class="reveal-on-scroll relative">
					<div class="absolute -inset-4 bg-electric/5 rounded-[50px] blur-2xl"></div>
					<div class="relative bg-navy rounded-[40px] p-12 text-white shadow-2xl overflow-hidden border border-white/5">
						<div class="absolute top-0 right-0 w-64 h-64 bg-electric opacity-10 rounded-full blur-[80px] -mr-32 -mt-32"></div>
						
						<h3 class="font-outfit text-4xl font-bold mb-6 relative z-10">Direct Access</h3>
						<p class="text-gray-400 mb-10 relative z-10 font-light text-lg">Speak directly with our academic coordinators for a personalized roadmap.</p>
						
						<form class="space-y-4 relative z-10">
							<input type="text" placeholder="Full Name" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-6 focus:border-electric transition-colors outline-none font-light">
							<input type="tel" placeholder="Phone Number" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-6 focus:border-electric transition-colors outline-none font-light">
							<button class="w-full bg-electric text-white font-bold py-5 rounded-2xl hover:bg-white hover:text-navy transition-all duration-500 shadow-xl shadow-electric/20 mt-4">Book Priority Counselling</button>
						</form>
						<p class="text-[10px] text-center text-gray-500 mt-6 uppercase tracking-widest">Limited Priority Slots Remaining</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<footer class="py-20 border-t border-gray-100 text-center bg-gray-50/50">
		<div class="mb-8">
			<a href="/" class="font-outfit text-xl font-bold text-navy tracking-tight">
				NUCLEUS <span class="text-electric">EDUCATION</span>
			</a>
		</div>
		<p class="text-gray-400 text-xs font-light tracking-widest uppercase italic">© 2026 Nucleus Education. All rights reserved. Designed for Excellence.</p>
	</footer>

