---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nucleus Education | Kota's Premier IIT-JEE & NEET Coaching">
	<!-- Hero Section -->
	<section class="relative bg-navy text-white min-h-[80vh] flex flex-col items-center justify-center px-4 overflow-hidden">
		<!-- Background decorative elements -->
		<div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-electric opacity-10 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-electric opacity-10 rounded-full blur-3xl"></div>

		<div class="container mx-auto text-center relative z-10">
			<div class="inline-block px-4 py-1 mb-6 border border-electric/30 bg-electric/10 text-electric rounded-full text-sm font-medium tracking-wide animate-pulse">
				ADMISSION OPEN 2024-25
			</div>
			<h1 class="font-rajdhani text-5xl md:text-7xl font-bold mb-4 tracking-tight leading-tight">
				NUCLEUS <span class="text-electric">EDUCATION</span>
			</h1>
			<p class="font-inter text-xl md:text-2xl text-gray-300 mb-10 max-w-2xl mx-auto">
				Kota's Premier IIT-JEE & NEET Coaching
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="https://wa.me/910000000000" class="bg-electric hover:bg-electric/90 text-white font-bold py-4 px-8 rounded-lg transition-all transform hover:scale-105 shadow-lg shadow-electric/20 flex items-center justify-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
					Enquire Now
				</a>
				<a href="#courses" class="bg-transparent border-2 border-white/30 hover:border-white text-white font-bold py-4 px-8 rounded-lg transition-all flex items-center justify-center">
					View Courses
				</a>
			</div>
		</div>
	</section>

	<!-- Courses Section -->
	<section id="courses" class="py-24 px-4 bg-gray-50">
		<div class="container mx-auto">
			<div class="text-center mb-16">
				<h2 class="font-rajdhani text-4xl md:text-5xl font-bold mb-4 text-navy">Our Courses</h2>
				<div class="w-20 h-1.5 bg-electric mx-auto rounded-full"></div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- IIT JEE Card -->
				<div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100 hover:border-electric/30 transition-all group">
					<div class="bg-navy text-white w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-electric transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
					</div>
					<h3 class="font-rajdhani text-2xl font-bold mb-2 text-navy">IIT JEE Advanced</h3>
					<p class="text-electric font-bold text-xl mb-4">₹1,00,000/yr</p>
					<ul class="space-y-3 mb-8 text-gray-600">
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Comprehensive Material</li>
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Expert Faculty</li>
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Regular Mock Tests</li>
					</ul>
					<a href="https://wa.me/910000000000" class="block text-center bg-navy text-white font-bold py-3 rounded-lg hover:bg-navy/90 transition-colors">Enquire</a>
				</div>

				<!-- NEET Card -->
				<div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100 hover:border-electric/30 transition-all group scale-105 border-electric/20 relative">
					<div class="absolute top-0 right-8 -translate-y-1/2 bg-electric text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">Popular</div>
					<div class="bg-navy text-white w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-electric transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2h-.2ZM11.6 12.7a.3.3 0 1 0 .2-.3h-.2ZM19.2 21.7a.3.3 0 1 0 .2-.3h-.2Z"></path><path d="M22 12A10 10 0 1 1 12 2"></path><path d="m7 7 10 10"></path><path d="m17 7-10 10"></path></svg>
					</div>
					<h3 class="font-rajdhani text-2xl font-bold mb-2 text-navy">NEET UG</h3>
					<p class="text-electric font-bold text-xl mb-4">₹70,000/yr</p>
					<ul class="space-y-3 mb-8 text-gray-600">
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> NCERT Focused Batch</li>
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Doubt Clearing Units</li>
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Daily Practice Sheets</li>
					</ul>
					<a href="https://wa.me/910000000000" class="block text-center bg-electric text-white font-bold py-3 rounded-lg hover:bg-electric/90 transition-colors shadow-lg shadow-electric/20">Enquire</a>
				</div>

				<!-- Foundation Card -->
				<div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100 hover:border-electric/30 transition-all group">
					<div class="bg-navy text-white w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-electric transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
					</div>
					<h3 class="font-rajdhani text-2xl font-bold mb-2 text-navy">Foundation (6-10)</h3>
					<p class="text-electric font-bold text-xl mb-4">Starts at Grade 6</p>
					<ul class="space-y-3 mb-8 text-gray-600">
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> NTSE & Olympiad Prep</li>
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Mental Ability Classes</li>
						<li class="flex items-center gap-2"><svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Conceptual Clarity</li>
					</ul>
					<a href="https://wa.me/910000000000" class="block text-center bg-navy text-white font-bold py-3 rounded-lg hover:bg-navy/90 transition-colors">Enquire</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Why Nucleus Section -->
	<section class="py-24 px-4 bg-navy text-white relative overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-electric/5 via-transparent to-transparent"></div>
		
		<div class="container mx-auto relative z-10">
			<div class="text-center mb-16">
				<h2 class="font-rajdhani text-4xl md:text-5xl font-bold mb-4">Why Nucleus?</h2>
				<div class="w-20 h-1.5 bg-electric mx-auto rounded-full"></div>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
				<div class="text-center group">
					<div class="w-16 h-16 bg-electric/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-electric/20 group-hover:bg-electric group-hover:border-electric transition-all duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
					</div>
					<h3 class="font-rajdhani text-xl font-bold mb-3 tracking-wide">Hostel Facility</h3>
					<p class="text-gray-400 text-sm leading-relaxed">Safe and comfortable living environment adjacent to the campus.</p>
				</div>

				<div class="text-center group">
					<div class="w-16 h-16 bg-electric/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-electric/20 group-hover:bg-electric group-hover:border-electric transition-all duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
					</div>
					<h3 class="font-rajdhani text-xl font-bold mb-3 tracking-wide">Doubt Sessions</h3>
					<p class="text-gray-400 text-sm leading-relaxed">Dedicated one-on-one doubt clearing support from our expert faculty.</p>
				</div>

				<div class="text-center group">
					<div class="w-16 h-16 bg-electric/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-electric/20 group-hover:bg-electric group-hover:border-electric transition-all duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
					</div>
					<h3 class="font-rajdhani text-xl font-bold mb-3 tracking-wide">Periodic Tests</h3>
					<p class="text-gray-400 text-sm leading-relaxed">Regular assessment with detailed performance analysis and ranking.</p>
				</div>

				<div class="text-center group">
					<div class="w-16 h-16 bg-electric/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-electric/20 group-hover:bg-electric group-hover:border-electric transition-all duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
					</div>
					<h3 class="font-rajdhani text-xl font-bold mb-3 tracking-wide">Distance Learning</h3>
					<p class="text-gray-400 text-sm leading-relaxed">Top-tier education accessible from anywhere with our digital platform.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section class="py-24 px-4 bg-white">
		<div class="container mx-auto max-w-5xl">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
				<div>
					<h2 class="font-rajdhani text-4xl font-bold mb-8 text-navy">Get In Touch</h2>
					<div class="space-y-8">
						<div class="flex gap-4">
							<div class="text-electric shrink-0 mt-1">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></circle><circle cx="12" cy="10" r="3"></circle></svg>
							</div>
							<div>
								<h4 class="font-bold text-navy mb-1">Address</h4>
								<p class="text-gray-600 leading-relaxed">
									Plot No. 92, Opposite Allen Safalya Building, Instrumentation Limited Colony, Rajeev Gandhi Nagar, Kota - 324005
								</p>
							</div>
						</div>

						<div class="flex gap-4">
							<div class="text-electric shrink-0 mt-1">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
							</div>
							<div>
								<h4 class="font-bold text-navy mb-1">Timings</h4>
								<p class="text-gray-600">Mon-Sun: 8AM - 10PM</p>
							</div>
						</div>
					</div>

					<div class="mt-10">
						<a href="https://wa.me/910000000000" class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-4 px-8 rounded-xl transition-all shadow-lg">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
							Chat on WhatsApp
						</a>
					</div>
				</div>

				<div class="bg-navy rounded-3xl p-10 text-white relative overflow-hidden">
					<div class="absolute top-0 right-0 w-32 h-32 bg-electric opacity-10 rounded-full -mr-16 -mt-16"></div>
					<h3 class="font-rajdhani text-3xl font-bold mb-6 relative z-10">Free Counselling</h3>
					<p class="text-gray-300 mb-8 relative z-10 leading-relaxed">Get expert guidance on your career path. Book a free 30-minute session with our senior counsellors.</p>
					
					<button class="w-full bg-white text-navy font-bold py-4 rounded-xl hover:bg-gray-100 transition-all relative z-10 mb-4">Book Free Counselling</button>
					<p class="text-xs text-center text-gray-400">Limited slots available for the current session.</p>
				</div>
			</div>
		</div>
	</section>

	<footer class="py-10 border-t border-gray-100 text-center">
		<p class="text-gray-500 text-sm">© 2024 Nucleus Education. All rights reserved.</p>
	</footer>

	<!-- Floating WhatsApp Button -->
	<a href="https://wa.me/910000000000" class="fixed bottom-8 right-8 w-16 h-16 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 transition-transform cursor-pointer z-[99999]" aria-label="Chat on WhatsApp">
		<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
	</a>
</Layout>
