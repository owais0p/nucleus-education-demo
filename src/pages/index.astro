---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nucleus Education | Trusted by JEE & NEET Aspirants Across India">
	<!-- Hero Section -->
	<section class="relative bg-navy text-white min-h-[80vh] flex flex-col items-center justify-center px-4 overflow-hidden pt-20 pb-12">
		<!-- Advanced Background -->
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,_rgba(30,144,255,0.12),transparent_50%)]"></div>
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-electric/5 rounded-full blur-[100px] -translate-y-1/2"></div>
		
		<!-- Decorative pattern -->
		<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>

		<div class="container mx-auto text-center relative z-10">
			<div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 border border-white/10 bg-white/5 backdrop-blur-md text-electric rounded-full text-[10px] font-bold tracking-[0.2em] uppercase animate-reveal" style="animation-delay: 0.1s">
				<span class="w-1.5 h-1.5 bg-electric rounded-full animate-pulse"></span>
				Admission Open 2026-27
			</div>
			
			<h1 class="font-outfit text-4xl md:text-7xl font-extrabold mb-6 tracking-tight leading-[1.05] animate-reveal" style="animation-delay: 0.2s">
				Trusted by <span class="text-electric">JEE & NEET</span><br/>
				Aspirants Across India
			</h1>
			
			<p class="font-jakarta text-sm md:text-lg text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed animate-reveal font-light" style="animation-delay: 0.3s">
				Expert faculty, strong academic culture, and result-oriented preparation <br class="hidden md:block" /> for competitive examinations in Kota.
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-reveal mb-12" style="animation-delay: 0.4s">
				<a href="https://wa.me/919783197831" class="group relative bg-electric text-white font-bold py-4 px-10 rounded-full transition-all overflow-hidden text-sm shadow-xl shadow-electric/20">
					<span class="relative z-10 flex items-center gap-2">
						Book Demo Class
						<svg class="group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</span>
				</a>
				<a href="tel:+919783197831" class="text-white font-bold py-4 px-10 rounded-full border border-white/20 hover:bg-white/5 transition-all text-sm flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
					Call Now
				</a>
			</div>

			<!-- Hero Trust Bar -->
			<div class="flex flex-wrap justify-center gap-4 md:gap-12 py-6 border-t border-white/5 animate-reveal" style="animation-delay: 0.5s">
				<div class="flex items-center gap-2">
					<span class="text-electric font-bold">4.5★</span>
					<span class="text-gray-400 text-[11px] uppercase tracking-wider">Student Rating</span>
				</div>
				<div class="hidden sm:block w-px h-4 bg-white/10 self-center"></div>
				<div class="flex items-center gap-2">
					<svg class="text-electric" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
					<span class="text-gray-300 text-[11px] uppercase tracking-wider font-medium">Kota, Rajasthan</span>
				</div>
				<div class="hidden sm:block w-px h-4 bg-white/10 self-center"></div>
				<div class="flex items-center gap-2">
					<span class="text-gray-300 text-[11px] uppercase tracking-wider font-medium">JEE & NEET Programs</span>
				</div>
				<div class="hidden sm:block w-px h-4 bg-white/10 self-center"></div>
				<div class="flex items-center gap-2">
					<span class="text-gray-300 text-[11px] uppercase tracking-wider font-medium">Session 2026-27</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Statistics Section -->
	<section class="bg-white py-12 border-b border-gray-100">
		<div class="container mx-auto px-4">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
				<div class="text-center reveal-on-scroll">
					<div class="font-outfit text-4xl md:text-5xl font-extrabold text-navy mb-1">
						<span class="counter" data-target="10000">0</span>+
					</div>
					<div class="text-gray-500 text-[11px] uppercase tracking-widest font-bold">Students Mentored</div>
				</div>
				<div class="text-center reveal-on-scroll">
					<div class="font-outfit text-4xl md:text-5xl font-extrabold text-electric mb-1">
						<span class="counter" data-target="500">0</span>+
					</div>
					<div class="text-gray-500 text-[11px] uppercase tracking-widest font-bold">Top Selections</div>
				</div>
				<div class="text-center reveal-on-scroll">
					<div class="font-outfit text-4xl md:text-5xl font-extrabold text-navy mb-1">
						<span class="counter" data-target="15">0</span>+
					</div>
					<div class="text-gray-500 text-[11px] uppercase tracking-widest font-bold">Years Excellence</div>
				</div>
				<div class="text-center reveal-on-scroll">
					<div class="font-outfit text-4xl md:text-5xl font-extrabold text-electric mb-1">
						<span class="counter" data-target="4.5" data-decimals="1">0</span>★
					</div>
					<div class="text-gray-500 text-[11px] uppercase tracking-widest font-bold">Student Rating</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Results Section -->
	<section id="results" class="py-20 px-4 bg-gray-50/50">
		<div class="container mx-auto">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<h2 class="font-outfit text-4xl md:text-6xl font-extrabold text-navy mb-4 tracking-tight">Proven Academic <span class="text-electric">Results</span></h2>
				<p class="font-jakarta text-gray-500 text-lg font-light">The consistent track record of our students in JEE and NEET is a testament to our academic rigor.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Result Card 1 -->
				<div class="reveal-on-scroll bg-white p-8 rounded-[32px] shadow-sm border border-gray-100 flex flex-col items-center text-center group hover:shadow-xl hover:shadow-electric/5 transition-all duration-500">
					<div class="w-24 h-24 bg-gray-100 rounded-full mb-6 overflow-hidden border-4 border-white shadow-md">
						<div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300"></div>
					</div>
					<h3 class="font-outfit text-2xl font-bold text-navy mb-1">JEE Advanced</h3>
					<div class="text-electric font-extrabold text-3xl mb-4">AIR 15</div>
					<p class="text-gray-500 text-sm font-light mb-6">Our student secured Top Rank in JEE Advanced through consistent performance and faculty guidance.</p>
					<div class="w-full py-3 bg-navy/5 rounded-xl text-navy font-bold text-xs uppercase tracking-widest group-hover:bg-electric group-hover:text-white transition-colors">Class of 2025</div>
				</div>

				<!-- Result Card 2 -->
				<div class="reveal-on-scroll bg-navy text-white p-8 rounded-[32px] shadow-2xl shadow-navy/20 flex flex-col items-center text-center relative overflow-hidden group hover:-translate-y-2 transition-all duration-500">
					<div class="absolute top-0 right-0 w-32 h-32 bg-electric/20 rounded-full blur-3xl -mr-16 -mt-16"></div>
					<div class="w-24 h-24 bg-white/10 rounded-full mb-6 overflow-hidden border-4 border-white/5 shadow-md">
						<div class="w-full h-full bg-gradient-to-br from-gray-600 to-gray-800"></div>
					</div>
					<h3 class="font-outfit text-2xl font-bold mb-1">NEET UG</h3>
					<div class="text-electric font-extrabold text-3xl mb-4">715 / 720</div>
					<p class="text-gray-300 text-sm font-light mb-6">Phenomenal score in NEET UG, highlighting our focused NCERT-based preparation strategy.</p>
					<div class="w-full py-3 bg-white/10 rounded-xl text-white font-bold text-xs uppercase tracking-widest">Top selection</div>
				</div>

				<!-- Result Card 3 -->
				<div class="reveal-on-scroll bg-white p-8 rounded-[32px] shadow-sm border border-gray-100 flex flex-col items-center text-center group hover:shadow-xl hover:shadow-electric/5 transition-all duration-500">
					<div class="w-24 h-24 bg-gray-100 rounded-full mb-6 overflow-hidden border-4 border-white shadow-md">
						<div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300"></div>
					</div>
					<h3 class="font-outfit text-2xl font-bold text-navy mb-1">JEE Main</h3>
					<div class="text-electric font-extrabold text-3xl mb-4">99.98 %ile</div>
					<p class="text-gray-500 text-sm font-light mb-6">Securing a near-perfect percentile in JEE Main through intensive practice and test series.</p>
					<div class="w-full py-3 bg-navy/5 rounded-xl text-navy font-bold text-xs uppercase tracking-widest group-hover:bg-electric group-hover:text-white transition-colors">Rankers Batch</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Student Success Stories Section -->
	<section id="testimonials" class="py-24 px-4 bg-white">
		<div class="container mx-auto">
			<div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-8 text-center md:text-left">
				<div class="max-w-2xl">
					<h2 class="font-outfit text-4xl md:text-5xl font-extrabold text-navy mb-4 tracking-tight">Student <span class="text-electric">Success Stories</span></h2>
					<p class="font-jakarta text-gray-500 text-lg font-light">Real stories from students who achieved their dreams with Nucleus.</p>
				</div>
				<a href="https://wa.me/919783197831" class="bg-navy text-white px-8 py-3.5 rounded-full font-bold text-sm hover:bg-electric transition-all shadow-lg shadow-navy/10">Read All Stories</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<!-- Testimonial 1 -->
				<div class="reveal-on-scroll bg-gray-50 p-10 rounded-[40px] border border-gray-100 relative group">
					<div class="absolute top-10 right-10 text-gray-200 group-hover:text-electric/20 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
					</div>
					<div class="flex items-center gap-4 mb-8">
						<div class="w-14 h-14 bg-gray-200 rounded-full overflow-hidden">
							<div class="w-full h-full bg-gradient-to-br from-gray-300 to-gray-400"></div>
						</div>
						<div>
							<h4 class="font-outfit font-bold text-navy">Rahul Sharma</h4>
							<p class="text-electric text-[10px] font-bold uppercase tracking-widest">IIT Delhi, CSE</p>
						</div>
					</div>
					<p class="text-gray-600 font-light italic leading-relaxed">"The faculty at Nucleus Education helped me simplify complex Physics concepts. The test series was exactly like the actual JEE Advanced paper."</p>
				</div>

				<!-- Testimonial 2 -->
				<div class="reveal-on-scroll bg-gray-50 p-10 rounded-[40px] border border-gray-100 relative group">
					<div class="absolute top-10 right-10 text-gray-200 group-hover:text-electric/20 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
					</div>
					<div class="flex items-center gap-4 mb-8">
						<div class="w-14 h-14 bg-gray-200 rounded-full overflow-hidden">
							<div class="w-full h-full bg-gradient-to-br from-gray-300 to-gray-400"></div>
						</div>
						<div>
							<h4 class="font-outfit font-bold text-navy">Priya Singh</h4>
							<p class="text-electric text-[10px] font-bold uppercase tracking-widest">AIIMS New Delhi</p>
						</div>
					</div>
					<p class="text-gray-600 font-light italic leading-relaxed">"Nucleus provided the perfect competitive environment. The regular doubt sessions and NCERT-focused approach in Biology were game-changers for my NEET prep."</p>
				</div>

				<!-- Testimonial 3 -->
				<div class="reveal-on-scroll bg-gray-50 p-10 rounded-[40px] border border-gray-100 relative group">
					<div class="absolute top-10 right-10 text-gray-200 group-hover:text-electric/20 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
					</div>
					<div class="flex items-center gap-4 mb-8">
						<div class="w-14 h-14 bg-gray-200 rounded-full overflow-hidden">
							<div class="w-full h-full bg-gradient-to-br from-gray-300 to-gray-400"></div>
						</div>
						<div>
							<h4 class="font-outfit font-bold text-navy">Aditya Gupta</h4>
							<p class="text-electric text-[10px] font-bold uppercase tracking-widest">IIT Bombay</p>
						</div>
					</div>
					<p class="text-gray-600 font-light italic leading-relaxed">"The HODs here are legends. Their teaching methods and the rigorous ranker's batch tests made AIR 100 possible for me."</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Why Choose Nucleus (Parent Trust Focus) -->
	<section id="why-nucleus" class="py-24 px-4 bg-navy text-white relative overflow-hidden">
		<div class="container mx-auto">
			<div class="text-center mb-16">
				<h2 class="font-outfit text-4xl md:text-6xl font-extrabold mb-4 tracking-tight">The Nucleus <span class="text-electric">Advantage</span></h2>
				<p class="font-jakarta text-gray-400 max-w-2xl mx-auto italic font-light">Comprehensive preparation tailored for competitive success.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				<!-- Advantage 1 -->
				<div class="reveal-on-scroll bg-white/5 border border-white/10 rounded-[32px] p-10 hover:bg-white/10 transition-all duration-500">
					<div class="w-14 h-14 bg-electric/20 rounded-2xl flex items-center justify-center mb-8 text-electric">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
					</div>
					<h3 class="font-outfit text-2xl font-bold mb-4">Experienced Faculty</h3>
					<p class="text-gray-400 font-light leading-relaxed">Mentorship by some of the most experienced HODs in the Kota coaching industry, ensuring conceptual clarity.</p>
				</div>

				<!-- Advantage 2 -->
				<div class="reveal-on-scroll bg-white/5 border border-white/10 rounded-[32px] p-10 hover:bg-white/10 transition-all duration-500">
					<div class="w-14 h-14 bg-electric/20 rounded-2xl flex items-center justify-center mb-8 text-electric">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
					</div>
					<h3 class="font-outfit text-2xl font-bold mb-4">Doubt Support</h3>
					<p class="text-gray-400 font-light leading-relaxed">One-on-one doubt clearing sessions to ensure every student keeps pace with the curriculum.</p>
				</div>

				<!-- Advantage 3 -->
				<div class="reveal-on-scroll bg-white/5 border border-white/10 rounded-[32px] p-10 hover:bg-white/10 transition-all duration-500">
					<div class="w-14 h-14 bg-electric/20 rounded-2xl flex items-center justify-center mb-8 text-electric">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
					</div>
					<h3 class="font-outfit text-2xl font-bold mb-4">Performance Tracking</h3>
					<p class="text-gray-400 font-light leading-relaxed">Regular tests followed by detailed analysis and parent-teacher communication for continuous improvement.</p>
				</div>
			</div>

			<div class="mt-16 flex flex-col md:flex-row items-center justify-center gap-10 border-t border-white/5 pt-16">
				<div class="flex items-center gap-4">
					<div class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center text-electric">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
					</div>
					<span class="text-white font-medium">IIT-JEE Focused Preparation</span>
				</div>
				<div class="flex items-center gap-4">
					<div class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center text-electric">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
					</div>
					<span class="text-white font-medium">Competitive Environment</span>
				</div>
				<div class="flex items-center gap-4">
					<div class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center text-electric">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
					</div>
					<span class="text-white font-medium">NCERT-Based NEET Strategy</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Academic Leadership Section -->
	<section class="py-24 px-4 bg-white">
		<div class="container mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
				<div class="reveal-on-scroll relative">
					<div class="aspect-[4/5] bg-gray-100 rounded-[40px] overflow-hidden border border-gray-100 shadow-2xl relative">
						<div class="absolute inset-0 bg-gradient-to-t from-navy/60 to-transparent flex flex-col justify-end p-12">
							<h3 class="font-outfit text-3xl font-bold text-white mb-2">Director's Message</h3>
							<p class="text-white/80 uppercase tracking-widest text-xs font-bold">Academic Leadership Team</p>
						</div>
						<!-- Placeholder for faculty image -->
						<div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300"></div>
					</div>
				</div>
				<div class="reveal-on-scroll">
					<div class="w-16 h-1 w-20 bg-electric mb-8"></div>
					<h2 class="font-outfit text-5xl font-extrabold text-navy mb-8 tracking-tight leading-tight">Guided by <span class="text-electric">Legacy</span>,<br /> Driven by Excellence.</h2>
					<blockquote class="font-jakarta text-2xl text-navy/80 italic font-medium leading-relaxed mb-10">
						"Success in competitive exams comes from strong concepts, disciplined practice, and continuous guidance."
					</blockquote>
					<div class="space-y-6 mb-12">
						<p class="text-gray-500 text-lg font-light leading-relaxed">
							At Nucleus, we don't just teach; we mentor students to navigate the high-pressure environment of competitive exams with confidence and precision. Our academic philosophy is built on three pillars: Concept Clarity, Rigorous Analysis, and Personalized Support.
						</p>
					</div>
					<a href="#contact" class="inline-flex items-center gap-3 bg-electric text-white font-bold py-4 px-10 rounded-full hover:bg-navy transition-all shadow-xl shadow-electric/20">
						Book Priority Counselling
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Courses Section -->
	<section id="courses" class="py-24 px-4 bg-gray-50/50">
